# App
NODE_ENV=development
PORT=3000
APP_NAME=Excellence
APP_URL=http://localhost:3000

# Auth / OTP
ENABLE_TEST_OTP=false
TEST_OTP=123456
ENABLE_WHATSAPP_OTP=false
OTP_EXPIRY_MINUTES=10

# Firebase Admin
FIREBASE_ADMIN_DISABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_FILE=firebase-admin-service-account.json

# Database (Neon / Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=90d

# Upload / Storage
UPLOAD_TMP_DIR=tmp/uploads/_incoming
UPLOAD_DIR=tmp/uploads
MAX_FILE_SIZE_MB=20
LOCAL_FILE_STORAGE=false

B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET_NAME=your-b2-bucket
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# Renflair WhatsApp OTP
RENFLAIR_API_KEY=your-renflair-api-key
RENFLAIR_COUNTRY_CODE=91

# YouTube Data API
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Proxy / networking (optional)
TRUST_PROXY_HOPS=1
TRUST_FORWARDED_FOR=false
